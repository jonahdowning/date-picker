{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "date-picker",
  "description": "Copy configurable dates to your clipboard or paste to the screen",
  "license": "MIT",
  "scripts": {
    "dev": "ray develop",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix",
    "build": "ray build",
    "publish": "npx @raycast/api@latest publish",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1"
  },
  "dependencies": {
    "@raycast/api": "^1.103.0",
    "@raycast/utils": "^2.2.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "icon": "extension-icon.png",
  "commands": [
    {
      "mode": "view",
      "name": "selectdate",
      "title": "Select Date",
      "subtitle": "Select a Date",
      "description": "lets you decide which date to pick"
    }
  ],
  "preferences": [
    {
      "name": "startOfWeek",
      "type": "dropdown",
      "required": false,
      "title": "Start of Week",
      "description": "Choose which day the week starts on",
      "default": "sunday",
      "data": [
        {
          "title": "Sunday",
          "value": "sunday"
        },
        {
          "title": "Monday",
          "value": "monday"
        }
      ]
    },
    {
      "name": "defaultDateFormat",
      "type": "textfield",
      "required": false,
      "title": "Default Date Format",
      "description": "Format for the copied date (e.g., M.d.y)",
      "default": "MM-dd-yyyy"
    },
    {
      "name": "preferredFormat1",
      "type": "textfield",
      "required": false,
      "title": "Preferred Format 1",
      "description": "Alternate format, accessible via ⌘+1"
    },
    {
      "name": "preferredFormat2",
      "type": "textfield",
      "required": false,
      "title": "Preferred Format 2",
      "description": "Alternate format, accessible via ⌘+2"
    },
    {
      "name": "preferredFormat3",
      "type": "textfield",
      "required": false,
      "title": "Preferred Format 3",
      "description": "Alternate format, accessible via ⌘+3"
    },
    {
      "name": "preferredFormat4",
      "type": "textfield",
      "required": false,
      "title": "Preferred Format 4",
      "description": "Alternate format, accessible via ⌘+4"
    },
    {
      "name": "preferredFormat5",
      "type": "textfield",
      "required": false,
      "title": "Preferred Format 5",
      "description": "Alternate format, accessible via ⌘+5"
    },
    {
      "name": "shortcutNextMonth",
      "type": "textfield",
      "required": false,
      "title": "Next Month Shortcut",
      "description": "Navigation shortcut (e.g., ctrl+n)",
      "default": "ctrl+n"
    },
    {
      "name": "shortcutPrevMonth",
      "type": "textfield",
      "required": false,
      "title": "Previous Month Shortcut",
      "description": "Navigation shortcut (e.g., ctrl+p)",
      "default": "ctrl+p"
    },
    {
      "name": "shortcutCurrentMonth",
      "type": "textfield",
      "required": false,
      "title": "Current Month Shortcut",
      "description": "Navigation shortcut (e.g., ctrl+c)",
      "default": "ctrl+c"
    },
    {
      "name": "shortcutNextYear",
      "type": "textfield",
      "required": false,
      "title": "Next Year Shortcut",
      "description": "Navigation shortcut (e.g., ctrl+shift+n)",
      "default": "ctrl+shift+n"
    },
    {
      "name": "shortcutPrevYear",
      "type": "textfield",
      "required": false,
      "title": "Previous Year Shortcut",
      "description": "Navigation shortcut (e.g., ctrl+shift+p)",
      "default": "ctrl+shift+p"
    }
  ],
  "title": "Date Picker",
  "author": "JoBro",
  "platforms": [
    "Windows",
    "macOS"
  ],
  "categories": [
    "Productivity"
  ]
}